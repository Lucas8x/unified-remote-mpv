<?xml version="1.0" encoding="utf-8" ?>
<layout
  onLaunch="launch"
  onVolumeUp="volume_up"
  onVolumeDown="volume_down"
  onResume="play_pause"
  onPause="play_pause"
  color="blue"
>
  <row weight="wrap">
    <label id="info" text="[Not Playing]" textAlign="center" />
  </row>
  <row>
    <button icon="vdown" onTap="volume_down" />
    <button icon="vmute" onTap="volume_mute" />
    <button icon="vup" onTap="volume_up" />
  </row>
  <row>
    <button icon="rwd" onTap="playback_speed_down" />
    <button icon="fullscreen" onTap="fullscreen" />
    <button icon="ff" onTap="playback_speed_up" />
  </row>
  <!-- <row>
    <button icon="previous" onTap="previous" />
    <button icon="next" onTap="next" />
  </row> -->
  <row>
    <button text="-3s" onTap="backward" />
    <button text="+3s" onTap="forward" />
  </row>
  <row>
    <button icon="stop" onTap="stop" />
    <button icon="playpause" onTap="play_pause" />
  </row>
</layout>
